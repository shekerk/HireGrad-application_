# Copy this file to `.env` in the backend folder and fill in real values.
# `.env` is gitignored; this example is committed as documentation.
DB_USERNAME=root
DB_PASSWORD=root
# Must be at least 32 characters (HS256). Generate a random one for production.
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# SMTP for outbound email. For Gmail, enable 2FA and create an App Password.
# Leave MAIL_USERNAME blank to disable email sending (the app still works).
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=HireGrad <your-email@gmail.com>
